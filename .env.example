# App
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173
HOME_BANNER_BACKGROUND_URL=

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=optivoy
DB_CONNECTION_TIMEOUT_MS=5000
DB_QUERY_TIMEOUT_MS=10000
# Optional connection pool tuning
DB_POOL_MAX=10
DB_POOL_MIN=2

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d
AUTH_REFRESH_COOKIE_NAME=optivoy_rt
AUTH_REFRESH_COOKIE_DOMAIN=
AUTH_REFRESH_COOKIE_PATH=/auth
AUTH_REFRESH_COOKIE_SAME_SITE=lax
AUTH_REFRESH_COOKIE_SECURE=false
AUTH_ADMIN_REFRESH_COOKIE_NAME=optivoy_admin_rt
AUTH_ADMIN_REFRESH_COOKIE_DOMAIN=
AUTH_ADMIN_REFRESH_COOKIE_PATH=/auth/admin
AUTH_ADMIN_REFRESH_COOKIE_SAME_SITE=strict
AUTH_ADMIN_REFRESH_COOKIE_SECURE=false

# Token TTL
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=60
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# Login rate limiting
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5

# Redis (required for admin 2FA challenge storage)
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Mail (MAIL_PROVIDER=log prints to console; use resend for real delivery)
MAIL_PROVIDER=log
MAIL_FROM=no-reply@optivoy.top
MAIL_APP_BASE_URL=http://localhost:3000
RESEND_API_KEY=

# OSS (Aliyun) — set OSS_ENABLED=true and fill all fields when using OSS
OSS_ENABLED=false
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_PUBLIC_BASE_URL=
OSS_UPLOAD_PREFIX=spots
OSS_MAX_FILE_SIZE_MB=10
OSS_MAX_FILES_PER_REQUEST=10
OSS_HOME_BANNER_MIN_IMAGE_WIDTH=1
OSS_HOME_BANNER_MIN_IMAGE_HEIGHT=1
OSS_HOME_BANNER_MAX_IMAGE_WIDTH=20000
OSS_HOME_BANNER_MAX_IMAGE_HEIGHT=20000
OSS_STS_ROLE_ARN=
OSS_STS_TOKEN_EXPIRES_SECONDS=900
OSS_STS_USER_PREFIX=uploads/users
OSS_STS_ADMIN_PREFIX=uploads/admin
OSS_UPLOAD_OBJECT_ACL=public-read

# Content moderation (Aliyun Green) — set OSS_MODERATION_ENABLED=true to activate
OSS_MODERATION_ENABLED=false
OSS_MODERATION_ACCESS_KEY_ID=
OSS_MODERATION_ACCESS_KEY_SECRET=
OSS_MODERATION_ENDPOINT=
OSS_MODERATION_REGION_ID=
OSS_MODERATION_SERVICE=baselineCheck_cb
OSS_MODERATION_FAIL_OPEN=false

# Admin seed (used by npm run seed:admin)
ADMIN_EMAIL=admin@optivoy.top
ADMIN_PASSWORD=change-me-admin-password
ADMIN_2FA_TTL_MINUTES=10
ADMIN_2FA_SECRET=change-me-admin-2fa-secret-min-32-chars

# Google OAuth (leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
# Optional custom endpoints (useful for proxy workers)
GOOGLE_AUTHORIZATION_URL=
GOOGLE_TOKEN_URL=
GOOGLE_USER_PROFILE_URL=
OAUTH_INITIAL_PASSWORD=Optivoy@2026
WEB_APP_BASE_URL=http://localhost:5173

# Facebook OAuth (leave blank to disable)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=
FACEBOOK_GRAPH_API_VERSION=v25.0
# Optional custom endpoints (useful for proxy workers)
FACEBOOK_AUTHORIZATION_URL=
FACEBOOK_TOKEN_URL=
FACEBOOK_PROFILE_URL=

# Trip deep links (flight/hotel standardized builder)
TRIP_DEFAULT_LOCALE=en-US
TRIP_DEFAULT_CURRENCY=USD
TRIP_FLIGHT_DEEPLINK_BASE_URL=https://www.trip.com/flights/showfarefirst
TRIP_HOTEL_DEEPLINK_BASE_URL=https://www.trip.com/hotels/list
TRIP_AFFILIATE_AID=
TRIP_AFFILIATE_SID=
TRIP_AFFILIATE_OUID=

# Amap nearby hotels (backend server-side REST call)
AMAP_ENABLED=false
AMAP_WEB_API_KEY=
AMAP_NEARBY_DEFAULT_RADIUS=5000
AMAP_NEARBY_MAX_LIMIT=20
AMAP_REQUEST_TIMEOUT_MS=8000
AMAP_DISTANCE_MATRIX_MAX_ORIGINS=25
AMAP_TRANSIT_DIRECTION_CONCURRENCY=1
AMAP_TRANSIT_REQUEST_MIN_INTERVAL_MS=220
AMAP_TRANSIT_QPS_RETRY_COUNT=3
AMAP_TRANSIT_QPS_BACKOFF_MS=1500

# Optimizer integration (route generation solver service)
OPTIMIZER_BASE_URL=http://127.0.0.1:8088
OPTIMIZER_SOLVE_PATH=/solve
OPTIMIZER_REQUEST_TIMEOUT_MS=30000
OPTIMIZER_DEFAULT_TIME_LIMIT_SECONDS=8

# Observability (set OTEL_ENABLED=true to export traces to local OTel Collector)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=optivoy-backend
OTEL_SERVICE_VERSION=0.0.1
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_TIMEOUT_MS=10000
OTEL_TRACE_SAMPLE_RATIO=0.2
