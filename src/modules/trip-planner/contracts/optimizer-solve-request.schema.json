{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optivoy.top/schemas/trip-planner/optimizer-solve-request.schema.json",
  "title": "OptimizerSolveRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "startDate",
    "paceMode",
    "hotelStrategy",
    "mealPolicy",
    "points",
    "hotels",
    "distanceMatrix"
  ],
  "properties": {
    "city": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "province": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 120
    },
    "startDate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "paceMode": {
      "type": "string",
      "enum": [
        "light",
        "standard",
        "compact"
      ]
    },
    "hotelStrategy": {
      "type": "string",
      "enum": [
        "single",
        "smart"
      ]
    },
    "mealPolicy": {
      "type": "string",
      "enum": [
        "auto",
        "off"
      ]
    },
    "points": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": {
        "$ref": "#/$defs/point"
      }
    },
    "hotels": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": {
        "$ref": "#/$defs/hotel"
      }
    },
    "distanceMatrix": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rows"
      ],
      "properties": {
        "rows": {
          "type": "array",
          "maxItems": 300000,
          "items": {
            "$ref": "#/$defs/distanceMatrixRow"
          }
        }
      }
    },
    "transportPreference": {
      "type": "string",
      "enum": [
        "transit_first",
        "driving_first",
        "mixed"
      ]
    },
    "maxIntradayDrivingMinutes": {
      "type": "integer",
      "minimum": 30,
      "maximum": 480
    }
  },
  "$defs": {
    "coordinate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "latitude": {
          "type": [
            "number",
            "null"
          ],
          "minimum": -90,
          "maximum": 90
        },
        "longitude": {
          "type": [
            "number",
            "null"
          ],
          "minimum": -180,
          "maximum": 180
        }
      }
    },
    "planningTimeRange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start",
        "end"
      ],
      "properties": {
        "start": {
          "type": "string",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        },
        "end": {
          "type": "string",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        }
      }
    },
    "openingHoursRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "weekday",
        "periods"
      ],
      "properties": {
        "weekday": {
          "type": "integer",
          "minimum": 0,
          "maximum": 6
        },
        "periods": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "$ref": "#/$defs/planningTimeRange"
          }
        }
      }
    },
    "queueProfile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "weekdayMinutes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1440
        },
        "weekendMinutes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1440
        },
        "holidayMinutes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1440
        }
      }
    },
    "distanceMatrixRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fromPointId",
        "toPointId",
        "transitMinutes",
        "drivingMinutes",
        "walkingMeters",
        "distanceKm"
      ],
      "properties": {
        "fromPointId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "toPointId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "transitMinutes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1440
        },
        "drivingMinutes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1440
        },
        "walkingMeters": {
          "type": "integer",
          "minimum": 0,
          "maximum": 200000
        },
        "walkingMinutes": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 2880
        },
        "distanceKm": {
          "type": "number",
          "minimum": 0,
          "maximum": 2000
        },
        "transitSummary": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "pointType",
        "suggestedDurationMinutes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "pointType": {
          "type": "string",
          "enum": [
            "spot",
            "shopping"
          ]
        },
        "suggestedDurationMinutes": {
          "type": "integer",
          "minimum": 10,
          "maximum": 720
        },
        "staminaFactor": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 3
        },
        "latitude": {
          "type": [
            "number",
            "null"
          ]
        },
        "longitude": {
          "type": [
            "number",
            "null"
          ]
        },
        "arrivalAnchor": {
          "$ref": "#/$defs/coordinate"
        },
        "departureAnchor": {
          "$ref": "#/$defs/coordinate"
        },
        "openingHoursJson": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/openingHoursRule"
          }
        },
        "specialClosureDates": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          }
        },
        "lastEntryTime": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        },
        "hasFoodCourt": {
          "type": "boolean"
        },
        "queueProfileJson": {
          "$ref": "#/$defs/queueProfile"
        }
      }
    },
    "hotel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "latitude": {
          "type": [
            "number",
            "null"
          ]
        },
        "longitude": {
          "type": [
            "number",
            "null"
          ]
        },
        "arrivalAnchor": {
          "$ref": "#/$defs/coordinate"
        },
        "departureAnchor": {
          "$ref": "#/$defs/coordinate"
        },
        "checkInTime": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        },
        "checkOutTime": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        }
      }
    }
  }
}
