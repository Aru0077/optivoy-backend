{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optivoy.top/schemas/trip-planner/optimizer-solve-request.schema.json",
  "title": "OptimizerSolveRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "arrivalDateTime",
    "airportBufferMinutes",
    "paceMode",
    "hotelMode",
    "mealPolicy",
    "points",
    "hotels",
    "distanceMatrix",
    "maxDays"
  ],
  "properties": {
    "city": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "province": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 120
    },
    "arrivalAirportCode": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "departureAirportCode": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "arrivalAirportId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "departureAirportId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "arrivalAirport": {
      "$ref": "#/$defs/coordinate"
    },
    "departureAirport": {
      "$ref": "#/$defs/coordinate"
    },
    "arrivalAirportBufferMinutes": {
      "type": "integer",
      "minimum": 0,
      "maximum": 480
    },
    "departureAirportBufferMinutes": {
      "type": "integer",
      "minimum": 0,
      "maximum": 480
    },
    "arrivalDateTime": {
      "type": "string",
      "format": "date-time"
    },
    "airportBufferMinutes": {
      "type": "integer",
      "minimum": 60,
      "maximum": 120
    },
    "paceMode": {
      "type": "string",
      "enum": [
        "light",
        "standard",
        "compact"
      ]
    },
    "hotelMode": {
      "type": "string",
      "enum": [
        "single",
        "multi"
      ]
    },
    "mealPolicy": {
      "type": "string",
      "enum": [
        "auto",
        "off"
      ]
    },
    "points": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": {
        "$ref": "#/$defs/point"
      }
    },
    "hotels": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": {
        "$ref": "#/$defs/hotel"
      }
    },
    "distanceMatrix": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rows"
      ],
      "properties": {
        "rows": {
          "type": "array",
          "maxItems": 300000,
          "items": {
            "$ref": "#/$defs/distanceMatrixRow"
          }
        }
      }
    },
    "maxDays": {
      "type": "integer",
      "minimum": 1,
      "maximum": 14
    },
    "transportPreference": {
      "type": "string",
      "enum": [
        "transit_first",
        "driving_first",
        "mixed"
      ]
    },
    "maxIntradayDrivingMinutes": {
      "type": "integer",
      "minimum": 30,
      "maximum": 480
    }
  },
  "$defs": {
    "coordinate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "latitude": {
          "type": [
            "number",
            "null"
          ],
          "minimum": -90,
          "maximum": 90
        },
        "longitude": {
          "type": [
            "number",
            "null"
          ],
          "minimum": -180,
          "maximum": 180
        }
      }
    },
    "weekday": {
      "type": "string",
      "enum": [
        "mon",
        "tue",
        "wed",
        "thu",
        "fri",
        "sat",
        "sun"
      ]
    },
    "timeRange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start",
        "end"
      ],
      "properties": {
        "start": {
          "type": "string",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        },
        "end": {
          "type": "string",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        }
      }
    },
    "openingHoursRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "weekday",
        "start",
        "end"
      ],
      "properties": {
        "weekday": {
          "$ref": "#/$defs/weekday"
        },
        "start": {
          "type": "string",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        },
        "end": {
          "type": "string",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        }
      }
    },
    "queueProfile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "weekdayMinutes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1440
        },
        "weekendMinutes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1440
        },
        "holidayMinutes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1440
        }
      }
    },
    "bestVisitWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start",
        "end",
        "tag"
      ],
      "properties": {
        "start": {
          "type": "string",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        },
        "end": {
          "type": "string",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        },
        "tag": {
          "type": "string",
          "minLength": 1,
          "maxLength": 48
        }
      }
    },
    "mealSlot": {
      "type": "string",
      "enum": [
        "breakfast",
        "lunch",
        "dinner",
        "night_snack"
      ]
    },
    "mealTimeWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot",
        "start",
        "end"
      ],
      "properties": {
        "slot": {
          "$ref": "#/$defs/mealSlot"
        },
        "start": {
          "type": "string",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        },
        "end": {
          "type": "string",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        }
      }
    },
    "bookingStatus": {
      "type": "string",
      "enum": [
        "available",
        "limited",
        "sold_out",
        "unknown"
      ]
    },
    "point": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "pointType",
        "suggestedDurationMinutes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "pointType": {
          "type": "string",
          "enum": [
            "spot",
            "shopping",
            "restaurant"
          ]
        },
        "suggestedDurationMinutes": {
          "type": "integer",
          "minimum": 10,
          "maximum": 720
        },
        "latitude": {
          "type": [
            "number",
            "null"
          ],
          "minimum": -90,
          "maximum": 90
        },
        "longitude": {
          "type": [
            "number",
            "null"
          ],
          "minimum": -180,
          "maximum": 180
        },
        "arrivalAnchor": {
          "$ref": "#/$defs/coordinate"
        },
        "departureAnchor": {
          "$ref": "#/$defs/coordinate"
        },
        "openingHoursJson": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/openingHoursRule"
          }
        },
        "specialClosureDates": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          }
        },
        "lastEntryTime": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        },
        "hasFoodCourt": {
          "type": "boolean"
        },
        "queueProfileJson": {
          "anyOf": [
            {
              "$ref": "#/$defs/queueProfile"
            },
            {
              "type": "null"
            }
          ]
        },
        "mealSlots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/mealSlot"
          }
        },
        "mealTimeWindowsJson": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/mealTimeWindow"
          }
        }
      }
    },
    "hotel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "latitude": {
          "type": [
            "number",
            "null"
          ],
          "minimum": -90,
          "maximum": 90
        },
        "longitude": {
          "type": [
            "number",
            "null"
          ],
          "minimum": -180,
          "maximum": 180
        },
        "arrivalAnchor": {
          "$ref": "#/$defs/coordinate"
        },
        "departureAnchor": {
          "$ref": "#/$defs/coordinate"
        },
        "foreignerFriendly": {
          "type": "boolean"
        },
        "checkInTime": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        },
        "checkOutTime": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
        },
        "bookingStatus": {
          "anyOf": [
            {
              "$ref": "#/$defs/bookingStatus"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "distanceMatrixRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fromPointId",
        "toPointId",
        "transitMinutes",
        "drivingMinutes",
        "walkingMeters",
        "distanceKm"
      ],
      "properties": {
        "fromPointId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "toPointId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "transitMinutes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1440
        },
        "drivingMinutes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1440
        },
        "walkingMeters": {
          "type": "integer",
          "minimum": 0,
          "maximum": 200000
        },
        "walkingMinutes": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 2880
        },
        "distanceKm": {
          "type": "number",
          "minimum": 0,
          "maximum": 2000
        },
        "transitSummary": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
